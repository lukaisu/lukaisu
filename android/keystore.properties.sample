# Release signing config for Lukaisu.
#
# Copy this file to `android/keystore.properties` (gitignored) and fill in real
# values, OR export the equivalent env vars (LUKAISU_KEYSTORE_FILE,
# LUKAISU_KEYSTORE_PASSWORD, LUKAISU_KEY_ALIAS, LUKAISU_KEY_PASSWORD).
#
# WARNING: back up the keystore file AND these passwords somewhere safe and
# permanent. The signing key is your app's identity on F-Droid and Play — if
# you lose it, existing users cannot upgrade; they must uninstall and reinstall
# a re-signed build. Never commit the keystore or this filled-in file.

storeFile=/absolute/path/to/lukaisu-release.jks
storePassword=CHANGE_ME
keyAlias=lukaisu
keyPassword=CHANGE_ME
