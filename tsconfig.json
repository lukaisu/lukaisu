{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "allowJs": false,
    "declaration": false,
    "noEmit": true,
    "paths": {
      "@/*": ["./webapp/js/*"],
      "@shared/*": ["./webapp/js/shared/*"],
      "@modules/*": ["./webapp/js/modules/*"],
      "@css/*": ["./webapp/css/base/*"],
      "@themes/*": ["./webapp/css/themes/*"]
    },
    "types": ["vite/client", "node"]
  },
  "include": ["webapp/js/**/*", "webapp/app/**/*", "capacitor.config.ts", "webapp.vite.config.ts"],
  "exclude": ["node_modules", "assets", "android"]
}
