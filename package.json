{
  "name": "lukaisu",
  "private": true,
  "version": "0.2.0",
  "description": "Lukaisu — the official mobile client for self-hosted Lukaisu Server instances",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite --config webapp.vite.config.ts",
    "build": "tsc --noEmit && vite build --config webapp.vite.config.ts",
    "build:themes": "node scripts/build-themes.js",
    "typecheck": "tsc --noEmit && npm run check:svelte",
    "check:svelte": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "e2e": "cypress run --config-file cypress.app.config.ts",
    "cy:open": "cypress open --config-file cypress.app.config.ts",
    "sync": "npm run build && npm run build:themes && cap sync android",
    "apk:debug": "npm run sync && cd android && ./gradlew assembleDebug",
    "apk:release": "npm run sync && cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/preferences": "^8.0.1",
    "@yaireo/tagify": "^4.35.6",
    "bulma": "^1.0.4",
    "chart.js": "^4.5.1",
    "dexie": "^4.2.1",
    "fflate": "^0.8.3",
    "lucide": "^1.7.0",
    "ts-fsrs": "^5.4.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@eslint/css": "^1.1.0",
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/node": "^25.5.2",
    "@types/yaireo__tagify": "^4.27.0",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "@vitest/coverage-v8": "^4.0.14",
    "cypress": "^15.16.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-svelte": "^3.20.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.1",
    "prettier": "^3.6.2",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.48.0",
    "vite": "^8.0.7",
    "vitest": "^4.0.14"
  }
}
